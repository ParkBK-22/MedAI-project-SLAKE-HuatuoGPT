# ==========================================
# 1. Data & Model Weights (가장 중요!)
# ==========================================
data/                   # SLAKE 데이터셋 (로컬/서버에서 직접 다운로드)
checkpoints/            # 학습된 모델 가중치 (.pth, .bin 등)
weights/                # HuatuoGPT 모델 가중치
*.pth
*.bin
*.pt
*.h5

# ==========================================
# 2. Python & Environments
# ==========================================
__pycache__/            # 파이썬 컴파일 캐시
.venv/                  # 로컬 가상환경 폴더
venv/
env/
*.py[cod]
*$py.class

# ==========================================
# 3. Experiment Results & Logs
# ==========================================
results/                # 실험 결과 CSV나 이미지 (용량이 커질 수 있음)
logs/                   # 훈련 로그 (Tensorboard, WandB 등)
*.log
*.csv
*.png
*.jpg

# ==========================================
# 4. OS & IDE Specific
# ==========================================
.DS_Store               # macOS 시스템 파일
Thumbs.db               # Windows 시스템 파일
.vscode/                # VS Code 설정 (팀원마다 다를 수 있음)
.idea/                  # PyCharm 설정

# ==========================================
# 5. Secrets & Configs
# ==========================================
.env                    # API 키 (HuggingFace 토큰 등)
configs/local_config.yaml # 로컬 전용 설정 파일